CAPI=2:
name: sharc:mem_ip:ram_1rw:0.0.1
description: SHARC Single Port RAM Component

filesets:
  model:
    files:
      - model/block_ram_model.v: {file_type: verilogSource}
  tb:
    files:
      - tb/block_ram_model_wtb.v:   {file_type: verilogSource}
      - tb/test_block_ram_model.py: {file_type: cocotbSource}

targets:
  default: &default
    filesets:
      - model

  tb:
    default_tool: verilator
    filesets:
      - model
      - tb